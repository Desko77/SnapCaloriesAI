# ============================================
# SnapCaloriesAI - настройки
# ============================================
# Скопируйте этот файл в .env и заполните значения:
#   cp .env.example .env
#
# Обязательные поля отмечены [ОБЯЗАТЕЛЬНО]
# ============================================

# --- Telegram [ОБЯЗАТЕЛЬНО] ---
BOT_TOKEN=вставьте_токен_бота

# --- AI Vision: основной провайдер ---
# openai_compat = OpenRouter / OpenAI (рекомендуется)
# gemini = Google Gemini (бесплатный тир, медленнее)
VISION_PROVIDER=openai_compat
VISION_FALLBACK=gemini

# --- OpenAI-совместимый [ОБЯЗАТЕЛЬНО] ---
# Для анализа фото (GPT-4.1 Mini через OpenRouter)
OPENAI_API_KEY=вставьте_ключ_openrouter
OPENAI_BASE_URL=https://openrouter.ai/api/v1
OPENAI_MODEL=openai/gpt-4.1-mini

# --- Локальная модель (LM Studio / Ollama) ---
# Если задан LOCAL_BASE_URL - используется для классификации и текстовых вопросов
# Если не задан - фолбек на Gemini (классификация) + GPT-4.1 Nano (текст)
LOCAL_BASE_URL=http://192.168.11.150:1234/v1
LOCAL_MODEL=google/gemma-4-26b-a4b
LOCAL_API_KEY=lm-studio
LOCAL_REASONING_EFFORT=none

# --- Фолбек для текстовых вопросов (если локальная модель недоступна) ---
TEXT_MODEL=openai/gpt-4.1-nano

# --- Google Gemini (фолбек для vision + классификация если нет локальной) ---
GEMINI_API_KEY=вставьте_ключ_gemini
GEMINI_MODEL=gemini-2.5-flash

# --- База данных ---
# PostgreSQL (рекомендуется для продакшена)
DATABASE_URL=postgresql+asyncpg://snap:snap@localhost:5432/snapcalories
# Пароль для PostgreSQL в Docker Compose
POSTGRES_PASSWORD=snap
