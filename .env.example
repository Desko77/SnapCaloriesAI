# Telegram
BOT_TOKEN=

# AI Vision - основной провайдер: gemini | openai_compat
VISION_PROVIDER=gemini
VISION_FALLBACK=openai_compat

# Google Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# OpenAI-совместимый (OpenAI, LM Studio, Ollama, Qwen, ...)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o

# Database
DATABASE_URL=sqlite+aiosqlite:///data/snapcalories.db
