# ============================================
# SnapCaloriesAI - настройки
# ============================================
# Скопируйте этот файл в .env и заполните значения:
#   cp .env.example .env
#
# Обязательные поля отмечены [ОБЯЗАТЕЛЬНО]
# ============================================

# --- Telegram [ОБЯЗАТЕЛЬНО] ---
# Получить у @BotFather в Telegram: /newbot -> скопировать токен
BOT_TOKEN=вставьте_токен_бота

# --- AI Vision: основной провайдер ---
# gemini = Google Gemini (рекомендуется, бесплатный тир)
# openai_compat = OpenAI / LM Studio / Ollama / Qwen
VISION_PROVIDER=gemini
VISION_FALLBACK=openai_compat

# --- Google Gemini [ОБЯЗАТЕЛЬНО если VISION_PROVIDER=gemini] ---
# Получить на https://aistudio.google.com/apikey
GEMINI_API_KEY=вставьте_ключ_gemini
GEMINI_MODEL=gemini-2.5-flash

# --- OpenAI-совместимый (опционально, фолбек) ---
# OpenAI: https://platform.openai.com/api-keys
# LM Studio: оставить пустым, указать только BASE_URL
# Ollama: оставить пустым, указать только BASE_URL
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o

# --- Примеры BASE_URL для локальных моделей ---
# LM Studio:  http://localhost:1234/v1
# Ollama:     http://localhost:11434/v1

# --- База данных ---
# По умолчанию SQLite в папке data/ (менять не нужно)
DATABASE_URL=sqlite+aiosqlite:///data/snapcalories.db
