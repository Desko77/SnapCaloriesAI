# ============================================
# SnapCaloriesAI - настройки
# ============================================
# Скопируйте этот файл в .env и заполните значения:
#   cp .env.example .env
#
# Обязательные поля отмечены [ОБЯЗАТЕЛЬНО]
# ============================================

# --- Telegram [ОБЯЗАТЕЛЬНО] ---
# Получить у @BotFather в Telegram: /newbot -> скопировать токен
BOT_TOKEN=вставьте_токен_бота

# --- AI Vision: основной провайдер ---
# openai_compat = OpenRouter / OpenAI / LM Studio / Ollama (рекомендуется)
# gemini = Google Gemini (бесплатный тир, медленнее)
VISION_PROVIDER=openai_compat
VISION_FALLBACK=gemini

# --- OpenAI-совместимый [ОБЯЗАТЕЛЬНО] ---
# OpenRouter (рекомендуется): https://openrouter.ai/keys
# OpenAI напрямую: https://platform.openai.com/api-keys
OPENAI_API_KEY=вставьте_ключ_openrouter
OPENAI_BASE_URL=https://openrouter.ai/api/v1
OPENAI_MODEL=openai/gpt-4.1-mini

# --- Google Gemini (фолбек) ---
# Получить на https://aistudio.google.com/apikey
GEMINI_API_KEY=вставьте_ключ_gemini
GEMINI_MODEL=gemini-2.5-flash

# --- Примеры BASE_URL ---
# OpenRouter:  https://openrouter.ai/api/v1
# OpenAI:     https://api.openai.com/v1
# LM Studio:  http://localhost:1234/v1
# Ollama:     http://localhost:11434/v1

# --- База данных ---
# По умолчанию SQLite в папке data/ (менять не нужно)
DATABASE_URL=sqlite+aiosqlite:///data/snapcalories.db
